# ================================
# Ruici AI 默认策略：第三方中转做主聊天，Qwen 做向量化/语音
# ================================

# Docker 镜像源（默认走官方镜像；ECS 可在 deploy/.env.ecs.example 覆盖）
POSTGRES_IMAGE=pgvector/pgvector:pg16
REDIS_IMAGE=redis:6.2.14
RUSTFS_IMAGE=rustfs/rustfs:latest
MINIO_MC_IMAGE=minio/mc
BACKEND_BUILDER_IMAGE=maven:3.9.11-eclipse-temurin-21
BACKEND_RUNTIME_IMAGE=eclipse-temurin:21-jre
FRONTEND_BUILDER_IMAGE=node:20-alpine
FRONTEND_RUNTIME_IMAGE=nginx:alpine

# 默认聊天 Provider
AI_DEFAULT_PROVIDER=third-party

# 第三方 OpenAI-compatible 中转（主聊天 / 情景模拟）
THIRD_PARTY_BASE_URL=https://api-s.zwenooo.link/v1
THIRD_PARTY_API_KEY=
THIRD_PARTY_MODEL=gpt5.2
THIRD_PARTY_FALLBACK_MODEL=qwen-plus

# DashScope / Qwen（向量化 + 语音）
AI_BAILIAN_API_KEY=
AI_EMBEDDING_MODEL=text-embedding-v3
# 兼容旧键名：虽然变量名叫 VOICE_INTERVIEW，但当前实际表示“语音交互模块默认 Provider”。
# 如果你只做文本能力，这个变量可以保持默认；如果启用语音链路，建议继续用 dashscope。
AI_EMBEDDING_MODEL=text-embedding-v3
APP_VOICE_INTERVIEW_LLM_PROVIDER=dashscope
AI_CHAT_FALLBACK_MODEL=qwen-plus
AI_TTS_MODEL=qwen3-tts-flash-realtime
AI_ASR_MODEL=qwen3-asr-flash-realtime

# ================================
# 基础设施配置 - 与 docker-compose.yml 对齐
# ================================

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=ruici_ai_platform
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

APP_STORAGE_ENDPOINT=http://localhost:9000
APP_STORAGE_ACCESS_KEY=minioadmin
APP_STORAGE_SECRET_KEY=minioadmin
APP_STORAGE_BUCKET=ruici-ai-platform
APP_STORAGE_REGION=us-east-1

# ================================
# 可选：其他 Provider
# ================================

OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.2

# LM Studio（本地调试）
# LMSTUDIO_BASE_URL=http://localhost:1234
# LMSTUDIO_API_KEY=lm-studio
# LMSTUDIO_MODEL=qwen2.5-7b-instruct

# 语音交互调优
# APP_VOICE_USER_UTTERANCE_DEBOUNCE_MS=2500
# APP_VOICE_ASR_SILENCE_MS=2000

# 情景模拟调优
# APP_INTERVIEW_FOLLOW_UP_COUNT=1
# APP_INTERVIEW_EVALUATION_BATCH_SIZE=8
